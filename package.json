  "scripts": {
    "dev": "bun --watch src/app.ts",
    "build": "bun build ./src/app.ts --outdir ./dist --target bun",
    "start": "bun ./dist/app.js",
    "start:dev": "bun --watch src/app.ts",
    "lint": "bun run eslint src --fix",
    "format": "prettier --write src",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate": "bunx prisma migrate deploy",
    "prisma:seed": "bunx prisma db seed",
    "test": "bun test",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hono/node-server": "^1.11.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "hono": "^4.6.0",
    "pg": "^8.21.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@types/bun": "^1.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  }
