{
  "name": "project-management-backend-hono",
  "version": "1.0.0",
  "description": "Project Management Backend - Bun + Hono",
  "private": true,
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/app.ts --outdir ./dist --target bun",
    "start": "bun ./dist/app.js",
    "start:dev": "bun --hot src/index.ts",
    "lint": "bun run eslint src --fix",
    "format": "prettier --write src",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate": "bunx prisma migrate deploy",
    "prisma:seed": "bunx prisma db seed",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/node-server": "^1.11.1",
    "@prisma/client": "^7.8.0",
    "hono": "^4.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^24.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  }
}
